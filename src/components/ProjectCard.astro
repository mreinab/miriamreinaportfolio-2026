---
interface Props {
  collection: string;
  slug: string;
  title: string;
  cover: string;
  tags: string[];
}

const { collection, slug, title, cover, tags } = Astro.props;
---

<article class="relative flex bg-paper project-card">
  <p class="project-card-title text-caption">{title}</p>
  <a class="w-full flex justify-end" href={`/${collection}/${slug}`}>
    <img class="project-cover" src={cover} alt={title} />
  </a>
  <!-- <ul>
    {tags.map((tag: string) => <li>{tag}</li>)}
  </ul> -->
</article>

<style>
  .project-card-title {
    position: absolute;
    bottom: 4px;
    left: 4px;
    right: 4px;
    color: transparent;
    text-transform: uppercase;
  }

  .project-card-title::after {
    content: "\2192";
    position: absolute;
    bottom: 4px;
    right: 4px;
    color: #ffffff;
    font-size: var(--text-caption);
    text-transform: uppercase;
  }

  .project-cover {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Solo tablet/desktop: en mobile la imagen se queda a ancho completo.
     Width libre (auto): cada imagen conserva su proporción natural y no
     todas miden lo mismo, pero todas comparten el mismo height. */
  @media (min-width: 768px) {
    .project-cover {
      width: auto;
      height: var(--project-cover-height, 32dvh);
    }

    /* Solo mobile: en tablet/desktop se oculta. */
    .project-card-title {
      display: none;
    }
  }

  /* En desktop, al hacer hover sobre la cover de esta misma card, se
     vuelve a mostrar el título — pero en color normal (ink), no paper:
     aquí no queda sobre la imagen (que está pegada a la derecha) sino
     sobre el hueco en blanco a su izquierda, donde el texto paper no se
     vería. */
  @media (min-width: 768px) and (hover: hover) and (pointer: fine) {
    .project-card:has(.project-cover:hover) .project-card-title {
      display: block;
      bottom: 50%;
      color: var(--color-ink);
    }

    .project-card:has(.project-cover:hover) .project-card-title::after {
      content: none;
    }
  }
</style>
