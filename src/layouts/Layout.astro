---
import '../styles/global.css';

interface Props {
  title?: string;
  chrome?: boolean;
  fonts?: boolean;
  favicon?: string;
}

const { title = 'Portfolio', chrome = true, fonts = false, favicon = '/favicon.png' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={favicon} />
    <title>{title}</title>
    {
      fonts && (
        <>
          <link rel="preconnect" href="https://fonts.googleapis.com" />
          <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
          <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap"
            rel="stylesheet"
          />
        </>
      )
    }
  </head>
  <body>
    {
      chrome && (
        <header>
          <nav>
            <ul>
              <li><a href="/">Inicio</a></li>
              <li><a href="/graphicdesign">Diseño</a></li>
              <li><a href="/fashion">Moda</a></li>
              <li><a href="/webdev">Desarrollo</a></li>
            </ul>
          </nav>
        </header>
      )
    }

    <main>
      <slot />
    </main>

    {
      chrome && (
        <footer>
          <p>&copy; {new Date().getFullYear()} Portfolio</p>
        </footer>
      )
    }
  </body>
</html>
