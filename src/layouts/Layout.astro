---
import '../styles/global.css';

interface Props {
  title?: string;
  fonts?: boolean;
  favicon?: string;
}

const { title = 'Portfolio', fonts = false, favicon = '/favicon.png' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={favicon} />
    <title>{title}</title>
    {
      fonts && (
        <>
          <link rel="preconnect" href="https://fonts.googleapis.com" />
          <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
          <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap"
            rel="stylesheet"
          />
        </>
      )
    }
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>

<script>
  // Mismo fade-in que usa el fondo del index: las imágenes dentro de un
  // <article> (cover de tarjeta, cover grande de detalle, galería del
  // markdown) arrancan invisibles y aparecen suavemente al cargar.
  function revealArticleImages() {
    const images = document.querySelectorAll<HTMLImageElement>('article img');

    images.forEach((img) => {
      if (img.complete) {
        img.classList.add('is-loaded');
      } else {
        img.addEventListener('load', () => img.classList.add('is-loaded'), { once: true });
      }
    });
  }

  revealArticleImages();
</script>
